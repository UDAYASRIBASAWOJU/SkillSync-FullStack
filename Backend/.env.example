# ============================================================
#  SkillSync - Environment Configuration Template
#  Copy this file to .env and fill in the real values
#  cp .env.example .env
# ============================================================

# ======================== DOCKER HUB ========================
DOCKERHUB_USERNAME=aksahoo1097

# ======================== DATABASE ==========================
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ======================== EUREKA ============================
EUREKA_HOST=skillsync-eureka

# ===================== CONFIG SERVER ========================
CONFIG_SERVER_HOST=skillsync-config

# ======================== RABBITMQ ==========================
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=CHANGE_ME_RABBITMQ_PASSWORD

# ======================== REDIS ==============================
REDIS_HOST=redis
REDIS_PORT=6379

# ======================== ZIPKIN ==============================
ZIPKIN_HOST=zipkin

# ======================== EMAIL =============================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=YOUR_GMAIL_APP_PASSWORD

# ======================== CORS ==============================
# Frontend domains allowed to call Gateway API
ALLOWED_ORIGINS=https://skillsync.udayasri.dev,https://skill-sync-sage.vercel.app,https://skillsync.udayasri.dev,https://skillsync.rangaraju.dev

# ======================== APP BASE URL ======================
# Used in user-facing email links (frontend domain)
APP_BASE_URL=https://skillsync.udayasri.dev

# Public URL used by OpenAPI server metadata for Swagger "Try it out"
APP_PUBLIC_BASE_URL=https://api.skillsync.udayasri.dev

# ======================== JPA ===============================
# Use 'update' for first run to create schemas, then switch to 'validate'
JPA_DDL_AUTO=validate

# ======================== JWT ===============================
JWT_SECRET=CHANGE_ME_BASE64_ENCODED_SECRET_KEY_AT_LEAST_256_BITS
JWT_ACCESS_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ======================== JVM ===============================
JAVA_OPTS=-Xms256m -Xmx512m -XX:+UseG1GC -XX:+UseContainerSupport
